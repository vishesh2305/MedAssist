# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/medassist_global?schema=public"

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="MedAssist Global <noreply@medassistglobal.com>"

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
SMS_MOCK=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# Google Places API (optional - enriches hospital data with real info)
GOOGLE_PLACES_API_KEY=

# Socket.IO
SOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

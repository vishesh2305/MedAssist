generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum TravelStatus {
  TOURIST
  LOCAL
}

enum UserRole {
  TRAVELER
  HOSPITAL_ADMIN
  SUPER_ADMIN
}

enum AvailabilityStatus {
  OPEN
  CLOSED
  LIMITED
}

enum EmergencyStatus {
  TRIGGERED
  RESPONDED
  RESOLVED
  CANCELLED
}

enum ChatRoomType {
  SUPPORT
  EMERGENCY
  CONSULTATION
}

enum SenderRole {
  USER
  HOSPITAL
  ADMIN
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  LOCATION
  SYSTEM
}

enum NotificationType {
  EMERGENCY
  CHAT
  REVIEW
  SYSTEM
  PROMOTION
  APPOINTMENT
}

// ─── Models ─────────────────────────────────────────────

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  phone                 String?       @unique
  passwordHash          String
  firstName             String
  lastName              String
  nationality           String?
  preferredLanguage     String        @default("en")
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalNotes          String?
  travelStatus          TravelStatus  @default(TOURIST)
  role                  UserRole      @default(TRAVELER)
  emailVerified         Boolean       @default(false)
  phoneVerified         Boolean       @default(false)
  avatarUrl             String?
  deviceTokens          String[]      @default([])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  sessions       Session[]
  reviews        Review[]
  favorites      Favorite[]
  emergencyLogs  EmergencyLog[]
  chatRooms      ChatRoom[]
  chatMessages   ChatMessage[]
  notifications  Notification[]
  recentlyViewed RecentlyViewed[]
  hospitals      Hospital[]       @relation("HospitalAdmin")

  // New feature relations
  medicalPassport   MedicalPassport?    @relation("UserMedicalPassport")
  documents         MedicalDocument[]   @relation("UserDocuments")
  consultations     Consultation[]      @relation("UserConsultations")
  payments          Payment[]           @relation("UserPayments")
  tripPlans         TripPlan[]          @relation("UserTripPlans")
  waitTimeReports   WaitTimeReport[]    @relation("UserWaitTimeReports")
  corporateEmployee CorporateEmployee[] @relation("CorporateUser")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@map("sessions")
}

model Hospital {
  id                  String             @id @default(uuid())
  name                String
  slug                String             @unique
  description         String?
  address             String
  city                String
  country             String
  latitude            Float
  longitude           Float
  phone               String
  email               String?
  website             String?
  coverImage          String?
  images              String[]           @default([])
  isVerified          Boolean            @default(false)
  isEmergencyCapable  Boolean            @default(false)
  availabilityStatus  AvailabilityStatus @default(OPEN)
  rating              Float              @default(0)
  reviewCount         Int                @default(0)
  adminUserId         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  adminUser      User?              @relation("HospitalAdmin", fields: [adminUserId], references: [id], onDelete: SetNull)
  languages      HospitalLanguage[]
  doctors        Doctor[]
  specialties    HospitalSpecialty[]
  pricing        Pricing[]
  reviews        Review[]
  favorites      Favorite[]
  emergencyLogs  EmergencyLog[]
  chatRooms      ChatRoom[]
  recentlyViewed RecentlyViewed[]

  // New feature relations
  consultations     Consultation[]         @relation("HospitalConsultations")
  waitTimeReports   WaitTimeReport[]       @relation("HospitalWaitTimes")
  partnership       HospitalPartnership[]  @relation("HospitalPartnership")
  packages          MedicalPackage[]       @relation("HospitalPackages")

  @@index([city])
  @@index([country])
  @@index([latitude, longitude])
  @@index([slug])
  @@index([isVerified])
  @@index([availabilityStatus])
  @@map("hospitals")
}

model HospitalLanguage {
  id         String @id @default(uuid())
  hospitalId String
  language   String

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, language])
  @@index([hospitalId])
  @@map("hospital_languages")
}

model Doctor {
  id              String   @id @default(uuid())
  hospitalId      String
  name            String
  specialty       String
  qualifications  String[]
  languages       String[]
  avatarUrl       String?
  isAvailable     Boolean  @default(true)
  consultationFee Float?
  experience      Int?
  createdAt       DateTime @default(now())

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  // New feature relations
  consultations Consultation[] @relation("DoctorConsultations")

  @@index([hospitalId])
  @@index([specialty])
  @@index([isAvailable])
  @@map("doctors")
}

model Specialty {
  id          String @id @default(uuid())
  name        String @unique
  icon        String?
  description String?

  hospitals HospitalSpecialty[]

  @@map("specialties")
}

model HospitalSpecialty {
  hospitalId  String
  specialtyId String

  hospital  Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  @@id([hospitalId, specialtyId])
  @@map("hospital_specialties")
}

model Pricing {
  id          String  @id @default(uuid())
  hospitalId  String
  serviceName String
  category    String
  minPrice    Float
  maxPrice    Float
  currency    String  @default("USD")
  description String?

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([category])
  @@map("pricing")
}

model Review {
  id         String   @id @default(uuid())
  hospitalId String
  userId     String
  rating     Int
  title      String?
  content    String
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([userId])
  @@index([isApproved])
  @@map("reviews")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  hospitalId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([userId, hospitalId])
  @@index([userId])
  @@map("favorites")
}

model EmergencyLog {
  id                String          @id @default(uuid())
  userId            String
  latitude          Float
  longitude         Float
  status            EmergencyStatus @default(TRIGGERED)
  nearestHospitalId String?
  ambulanceCalled   Boolean         @default(false)
  notes             String?
  createdAt         DateTime        @default(now())
  resolvedAt        DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nearestHospital Hospital? @relation(fields: [nearestHospitalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("emergency_logs")
}

model ChatRoom {
  id         String       @id @default(uuid())
  name       String?
  type       ChatRoomType @default(SUPPORT)
  userId     String
  hospitalId String?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital?     @relation(fields: [hospitalId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([hospitalId])
  @@index([isActive])
  @@map("chat_rooms")
}

model ChatMessage {
  id                String      @id @default(uuid())
  chatRoomId        String
  senderId          String
  senderRole        SenderRole
  content           String
  translatedContent String?
  messageType       MessageType @default(TEXT)
  isRead            Boolean     @default(false)
  createdAt         DateTime    @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType @default(SYSTEM)
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model RecentlyViewed {
  id         String   @id @default(uuid())
  userId     String
  hospitalId String
  viewedAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([userId, hospitalId])
  @@index([userId])
  @@index([viewedAt])
  @@map("recently_viewed")
}

// ─── Medical Passport ─────────────────────────────
model MedicalPassport {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation("UserMedicalPassport", fields: [userId], references: [id], onDelete: Cascade)
  bloodType         String?  // A+, A-, B+, B-, AB+, AB-, O+, O-
  allergies         String[] // Array of allergy strings
  medications       String[] // Current medications
  conditions        String[] // Chronic conditions
  vaccinations      Json?    // Array of {name, date, expiryDate}
  insuranceProvider String?
  insurancePolicyNo String?
  insurancePhone    String?
  insuranceExpiry   DateTime?
  qrCodeData        String?  // Encrypted JSON for QR code
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("medical_passports")
}

// ─── Medical Documents ────────────────────────────
model MedicalDocument {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  title       String
  type        DocumentType
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  description String?
  metadata    Json?    // OCR extracted data, tags, etc.
  shareToken  String?  @unique // For sharing via link
  shareExpiry DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("medical_documents")
}

enum DocumentType {
  PRESCRIPTION
  LAB_REPORT
  XRAY
  DISCHARGE_SUMMARY
  INSURANCE_CARD
  VACCINATION_RECORD
  OTHER
}

// ─── Telemedicine Consultations ───────────────────
model Consultation {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation("UserConsultations", fields: [userId], references: [id])
  doctorId     String?
  doctor       Doctor?            @relation("DoctorConsultations", fields: [doctorId], references: [id])
  hospitalId   String?
  hospital     Hospital?          @relation("HospitalConsultations", fields: [hospitalId], references: [id])
  type         ConsultationType
  status       ConsultationStatus @default(SCHEDULED)
  scheduledAt  DateTime
  startedAt    DateTime?
  endedAt      DateTime?
  duration     Int?               // minutes
  roomId       String?            // WebRTC room ID
  notes        String?
  prescription String?
  amount       Float?
  currency     String?            @default("USD")
  paymentId    String?
  rating       Int?
  feedback     String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId])
  @@index([doctorId])
  @@map("consultations")
}

enum ConsultationType {
  VIDEO
  AUDIO
  CHAT
}

enum ConsultationStatus {
  SCHEDULED
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── Payments ─────────────────────────────────────
model Payment {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation("UserPayments", fields: [userId], references: [id])
  amount            Float
  currency          String        @default("USD")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("stripe") // stripe, razorpay
  providerPaymentId String?       @unique
  consultationId    String?
  hospitalId        String?
  description       String?
  receiptUrl        String?
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
  @@index([providerPaymentId])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Trip Health Planner ──────────────────────────
model TripPlan {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation("UserTripPlans", fields: [userId], references: [id], onDelete: Cascade)
  destination      String   // City or country
  destinationCode  String?  // ISO country code
  startDate        DateTime
  endDate          DateTime
  checklist        Json?    // Generated health checklist
  vaccinations     Json?    // Required/recommended vaccinations
  emergencyNumbers Json?    // Local emergency numbers
  healthAlerts     Json?    // Active health alerts
  nearbyHospitals  Json?    // Pre-cached hospital data
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@map("trip_plans")
}

// ─── Hospital Wait Times ──────────────────────────
model WaitTimeReport {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserWaitTimeReports", fields: [userId], references: [id])
  hospitalId  String
  hospital    Hospital @relation("HospitalWaitTimes", fields: [hospitalId], references: [id])
  department  String?  // ER, General, Specialist
  waitMinutes Int
  reportedAt  DateTime @default(now())

  @@index([hospitalId, reportedAt])
  @@map("wait_time_reports")
}

// ─── Hospital Partnerships ────────────────────────
model HospitalPartnership {
  id         String            @id @default(uuid())
  hospitalId String
  hospital   Hospital          @relation("HospitalPartnership", fields: [hospitalId], references: [id])
  tier       PartnershipTier   @default(BASIC)
  features   String[]          // premium_listing, top_placement, analytics, booking
  monthlyFee Float?
  status     PartnershipStatus @default(ACTIVE)
  startDate  DateTime          @default(now())
  endDate    DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([hospitalId])
  @@map("hospital_partnerships")
}

enum PartnershipTier {
  BASIC
  PREMIUM
  ENTERPRISE
}

enum PartnershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELLED
}

// ─── Medical Tourism Packages ─────────────────────
model MedicalPackage {
  id          String    @id @default(uuid())
  hospitalId  String?
  hospital    Hospital? @relation("HospitalPackages", fields: [hospitalId], references: [id])
  title       String
  description String
  category    String   // dental, cosmetic, orthopedic, eye, cardiac
  procedure   String
  country     String
  city        String
  price       Float
  currency    String   @default("USD")
  duration    String   // e.g., "5 days"
  includes    String[] // flights, hotel, hospital, recovery
  images      String[]
  rating      Float?
  reviewCount Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("medical_packages")
}

// ─── Corporate Programs ───────────────────────────
model CorporateProgram {
  id            String   @id @default(uuid())
  companyName   String
  contactName   String
  contactEmail  String
  contactPhone  String?
  employeeCount Int?
  plan          String   @default("standard") // standard, premium, enterprise
  status        String   @default("active")
  features      String[]
  monthlyFee    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employees CorporateEmployee[]

  @@map("corporate_programs")
}

model CorporateEmployee {
  id         String           @id @default(uuid())
  programId  String
  program    CorporateProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?            @relation("CorporateUser", fields: [userId], references: [id])
  name       String
  email      String
  department String?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())

  @@index([programId])
  @@map("corporate_employees")
}
